---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const allPosts = await getCollection('blog');
const { Content } = await render(post);

const isZh = post.data.lang === 'zh';
const backLabel = isZh ? '← 返回博客' : '← Back to Blog';

// Find the counterpart article in the other language
const bareSlug = post.id.replace(/^(?:zh|en)\//, '');
const altLang = isZh ? 'en' : 'zh';
const altPost = allPosts.find(p => p.data.lang === altLang && p.id.replace(/^(?:zh|en)\//, '') === bareSlug);
const altUrl = altPost ? `/blog/${altPost.id}/` : '/blog/';

function formatDate(date: Date): string {
  if (isZh) return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<Base
  title={`${post.data.title} — PicoClaw Blog`}
  description={post.data.description}
  canonical={`https://picoclaw.io/blog/${post.id}/`}
  lang={post.data.lang}
>
  <Nav active="blog" />

  <article class="blog-article" data-lang={post.data.lang} data-alt-url={altUrl}>
    <header class="article-header">
      <a href="/blog/" class="back-link">{backLabel}</a>
      <h1 class="article-title reveal d1">{post.data.title}</h1>
      <div class="article-meta reveal d2">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        <span class="meta-sep">&middot;</span>
        <span>{post.data.author}</span>
      </div>
      <div class="article-tags reveal d2">
        {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </header>

    <div class="article-body reveal d3" style={post.data.imageWidth ? `--img-max-w: ${post.data.imageWidth}%` : undefined}>
      <Content />
    </div>

    <footer class="article-footer">
      <a href="/blog/" class="back-link">{backLabel}</a>
    </footer>
  </article>

  <!-- Image lightbox -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Image preview">
    <button class="lightbox-close" id="lightbox-close" aria-label="Close">&times;</button>
    <div class="lightbox-main">
      <button class="lightbox-nav lightbox-prev" id="lightbox-prev" aria-label="Previous">&#8249;</button>
      <img class="lightbox-img" id="lightbox-img" src="" alt="" />
      <button class="lightbox-nav lightbox-next" id="lightbox-next" aria-label="Next">&#8250;</button>
    </div>
    <div class="lightbox-bottom">
      <div class="lightbox-thumbs" id="lightbox-thumbs"></div>
      <div class="lightbox-counter" id="lightbox-counter"></div>
    </div>
  </div>

  <Footer />
</Base>

<script>
  import { initLightbox } from '../../lib/lightbox';

  document.addEventListener('astro:page-load', () => {
    const article = document.querySelector<HTMLElement>('.blog-article[data-lang]');
    if (!article) return;
    const altUrl = article.dataset.altUrl || '/blog/';

    const controller = new AbortController();

    window.addEventListener('lang-changed', (e: any) => {
      const targetLang = e.detail.lang as string;
      const currentLang = article.dataset.lang;
      if (targetLang !== currentLang) {
        window.location.href = altUrl;
      }
    }, { signal: controller.signal });

    // Remove listener when navigating away from this article page
    document.addEventListener('astro:before-swap', () => controller.abort(), { once: true });

    // ── Image lightbox ──
    initLightbox(controller.signal);
  });
</script>

<style>

  .blog-article {
    position: relative; z-index: 1;
    max-width: 720px; margin: 0 auto; padding: 0 20px 60px;
  }

  .article-header { margin-bottom: 32px; }
  .back-link {
    display: inline-block; font-size: 0.82rem; color: var(--accent);
    text-decoration: none; margin-bottom: 20px;
  }
  .back-link:hover { text-decoration: underline; }

  .article-title {
    font-size: clamp(1.5rem, 4vw, 2.2rem); font-weight: 800;
    line-height: 1.3; color: var(--text); margin-bottom: 14px;
  }
  .article-meta {
    font-size: 0.82rem; color: var(--text-muted); margin-bottom: 12px;
    display: flex; align-items: center; gap: 8px;
  }
  .meta-sep { color: var(--border-h); }
  .article-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .tag {
    padding: 2px 8px; border-radius: 4px; font-size: 0.68rem;
    background: rgba(88,166,255,.1); color: var(--accent); border: 1px solid rgba(88,166,255,.2);
  }

  /* Article body — markdown content styling */
  .article-body {
    font-size: 0.95rem; line-height: 1.8; color: var(--text);
  }
  .article-body :global(h2) {
    font-size: 1.3rem; font-weight: 700; color: var(--text);
    margin: 40px 0 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border);
  }
  .article-body :global(h3) {
    font-size: 1.05rem; font-weight: 600; color: var(--text); margin: 28px 0 12px;
  }
  .article-body :global(p) { margin: 16px 0; }
  .article-body :global(img) { max-width: var(--img-max-w, 100%); height: auto; border-radius: 10px; display: block; margin-left: auto; margin-right: auto; }
  .article-body :global(a) { color: var(--accent); text-decoration: none; }
  .article-body :global(a:hover) { text-decoration: underline; }
  .article-body :global(strong) { color: var(--text); font-weight: 600; }
  .article-body :global(ul), .article-body :global(ol) {
    padding-left: 24px; margin: 12px 0;
  }
  .article-body :global(li) { margin: 6px 0; }
  .article-body :global(code) {
    padding: 1px 6px; border-radius: 4px; background: rgba(0,0,0,.3);
    font-family: 'JetBrains Mono', monospace; font-size: 0.85em; color: var(--accent);
  }
  .article-body :global(pre) {
    background: rgba(0,0,0,.4); border: 1px solid var(--border); border-radius: 10px;
    padding: 16px 20px; margin: 16px 0; overflow-x: auto; font-size: 0.82rem;
    line-height: 1.6;
  }
  .article-body :global(pre code) {
    padding: 0; background: none; color: var(--text); font-size: inherit;
  }
  .article-body :global(table) {
    width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 0.88rem;
  }
  .article-body :global(th),
  .article-body :global(td) {
    border: 1px solid var(--border); padding: 8px 14px; text-align: left;
  }
  .article-body :global(th) {
    background: rgba(88,166,255,.08); color: var(--text); font-weight: 600;
  }
  .article-body :global(tr:nth-child(even) td) {
    background: rgba(255,255,255,.03);
  }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--accent); padding: 8px 16px; margin: 16px 0;
    background: rgba(88,166,255,.05); border-radius: 0 8px 8px 0;
    color: var(--text-muted);
  }

  .article-footer {
    margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--border);
  }

  /* ─── Lightbox ─── */
  .lightbox {
    position: fixed; inset: 0; z-index: 1000;
    display: flex; flex-direction: column;
    background: rgba(0, 0, 0, .88);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    opacity: 0; pointer-events: none;
    transition: opacity .25s ease;
  }
  .lightbox.open { opacity: 1; pointer-events: all; }

  .lightbox-close {
    position: absolute; top: 12px; right: 16px;
    background: none; border: none; color: rgba(255,255,255,.6);
    font-size: 2rem; line-height: 1; cursor: pointer; z-index: 2;
    transition: color .15s;
  }
  .lightbox-close:hover { color: #fff; }

  .lightbox-main {
    flex: 1; display: flex; align-items: center; justify-content: center;
    position: relative; min-height: 0; padding: 16px 60px;
  }

  .lightbox-img {
    max-width: 90vw; max-height: calc(100vh - 120px);
    border-radius: 8px;
    box-shadow: 0 12px 48px rgba(0,0,0,.5);
    object-fit: contain;
    transform-origin: center center;
    will-change: transform;
    cursor: zoom-in;
    user-select: none;
    -webkit-user-drag: none;
  }

  .lightbox-nav {
    position: absolute; top: 50%; transform: translateY(-50%);
    background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12);
    color: rgba(255,255,255,.7); font-size: 1.6rem; line-height: 1;
    width: 40px; height: 40px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; z-index: 2;
    transition: background .15s, color .15s;
  }
  .lightbox-nav:hover { background: rgba(255,255,255,.18); color: #fff; }
  .lightbox-prev { left: 12px; }
  .lightbox-next { right: 12px; }

  .lightbox-bottom {
    flex-shrink: 0;
    display: flex; flex-direction: column; align-items: center;
    gap: 8px; padding: 10px 16px 14px;
  }

  .lightbox-thumbs {
    display: flex; gap: 6px; overflow-x: auto;
    max-width: 90vw; padding: 2px;
    scrollbar-width: thin; scrollbar-color: rgba(255,255,255,.15) transparent;
  }
  .lightbox-thumbs::-webkit-scrollbar { height: 4px; }
  .lightbox-thumbs::-webkit-scrollbar-thumb { background: rgba(255,255,255,.15); border-radius: 2px; }
  :global(.lb-thumb) {
    width: 48px; height: 36px; object-fit: cover;
    border-radius: 4px; cursor: pointer; flex-shrink: 0;
    border: none; outline: 2px solid transparent; outline-offset: -2px;
    opacity: .45;
    transition: opacity .15s, outline-color .15s;
  }
  :global(.lb-thumb:hover) { opacity: .7; }
  :global(.lb-thumb.active) { opacity: 1; outline-color: var(--accent); }

  .lightbox-counter {
    font-size: 0.72rem; color: rgba(255,255,255,.4);
    pointer-events: none;
  }

  @media (max-width: 600px) {
    .lightbox-main { padding: 12px 44px; }
    .lightbox-nav { width: 32px; height: 32px; font-size: 1.2rem; }
    .lightbox-prev { left: 6px; }
    .lightbox-next { right: 6px; }
    :global(.lb-thumb) { width: 40px; height: 30px; }
  }

</style>
