---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const allPosts = await getCollection('blog');
const { Content } = await render(post);

const isZh = post.data.lang === 'zh';
const backLabel = isZh ? '← 返回博客' : '← Back to Blog';

// Find the counterpart article in the other language
const bareSlug = post.id.replace(/^(?:zh|en)\//, '');
const altLang = isZh ? 'en' : 'zh';
const altPost = allPosts.find(p => p.data.lang === altLang && p.id.replace(/^(?:zh|en)\//, '') === bareSlug);
const altUrl = altPost ? `/blog/${altPost.id}/` : '/blog/';

function formatDate(date: Date): string {
  if (isZh) return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<Base
  title={`${post.data.title} — PicoClaw Blog`}
  description={post.data.description}
  canonical={`https://picoclaw.io/blog/${post.id}/`}
  lang={post.data.lang}
>
  <Nav active="blog" />

  <article class="blog-article" data-lang={post.data.lang} data-alt-url={altUrl}>
    <header class="article-header">
      <a href="/blog/" class="back-link">{backLabel}</a>
      <h1 class="article-title reveal d1">{post.data.title}</h1>
      <div class="article-meta reveal d2">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        <span class="meta-sep">&middot;</span>
        <span>{post.data.author}</span>
      </div>
      <div class="article-tags reveal d2">
        {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </header>

    <div class="article-body reveal d3" style={post.data.imageWidth ? `--img-max-w: ${post.data.imageWidth}%` : undefined}>
      <Content />
    </div>

    <footer class="article-footer">
      <a href="/blog/" class="back-link">{backLabel}</a>
    </footer>
  </article>

  <Footer />
</Base>

<script>
  document.addEventListener('astro:page-load', () => {
    const article = document.querySelector<HTMLElement>('.blog-article[data-lang]');
    if (!article) return;
    const altUrl = article.dataset.altUrl || '/blog/';

    const controller = new AbortController();

    window.addEventListener('lang-changed', (e: any) => {
      const targetLang = e.detail.lang as string;
      const currentLang = article.dataset.lang;
      if (targetLang !== currentLang) {
        window.location.href = altUrl;
      }
    }, { signal: controller.signal });

    // Remove listener when navigating away from this article page
    document.addEventListener('astro:before-swap', () => controller.abort(), { once: true });
  });
</script>

<style>

  .blog-article {
    position: relative; z-index: 1;
    max-width: 720px; margin: 0 auto; padding: 0 20px 60px;
  }

  .article-header { margin-bottom: 32px; }
  .back-link {
    display: inline-block; font-size: 0.82rem; color: var(--accent);
    text-decoration: none; margin-bottom: 20px;
  }
  .back-link:hover { text-decoration: underline; }

  .article-title {
    font-size: clamp(1.5rem, 4vw, 2.2rem); font-weight: 800;
    line-height: 1.3; color: var(--text); margin-bottom: 14px;
  }
  .article-meta {
    font-size: 0.82rem; color: var(--text-muted); margin-bottom: 12px;
    display: flex; align-items: center; gap: 8px;
  }
  .meta-sep { color: var(--border-h); }
  .article-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .tag {
    padding: 2px 8px; border-radius: 4px; font-size: 0.68rem;
    background: rgba(88,166,255,.1); color: var(--accent); border: 1px solid rgba(88,166,255,.2);
  }

  /* Article body — markdown content styling */
  .article-body {
    font-size: 0.95rem; line-height: 1.8; color: var(--text);
  }
  .article-body :global(h2) {
    font-size: 1.3rem; font-weight: 700; color: var(--text);
    margin: 40px 0 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border);
  }
  .article-body :global(h3) {
    font-size: 1.05rem; font-weight: 600; color: var(--text); margin: 28px 0 12px;
  }
  .article-body :global(p) { margin: 16px 0; }
  .article-body :global(img) { max-width: var(--img-max-w, 100%); height: auto; border-radius: 10px; display: block; margin-left: auto; margin-right: auto; }
  .article-body :global(a) { color: var(--accent); text-decoration: none; }
  .article-body :global(a:hover) { text-decoration: underline; }
  .article-body :global(strong) { color: var(--text); font-weight: 600; }
  .article-body :global(ul), .article-body :global(ol) {
    padding-left: 24px; margin: 12px 0;
  }
  .article-body :global(li) { margin: 6px 0; }
  .article-body :global(code) {
    padding: 1px 6px; border-radius: 4px; background: rgba(0,0,0,.3);
    font-family: 'JetBrains Mono', monospace; font-size: 0.85em; color: var(--accent);
  }
  .article-body :global(pre) {
    background: rgba(0,0,0,.4); border: 1px solid var(--border); border-radius: 10px;
    padding: 16px 20px; margin: 16px 0; overflow-x: auto; font-size: 0.82rem;
    line-height: 1.6;
  }
  .article-body :global(pre code) {
    padding: 0; background: none; color: var(--text); font-size: inherit;
  }
  .article-body :global(table) {
    width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 0.88rem;
  }
  .article-body :global(th),
  .article-body :global(td) {
    border: 1px solid var(--border); padding: 8px 14px; text-align: left;
  }
  .article-body :global(th) {
    background: rgba(88,166,255,.08); color: var(--text); font-weight: 600;
  }
  .article-body :global(tr:nth-child(even) td) {
    background: rgba(255,255,255,.03);
  }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--accent); padding: 8px 16px; margin: 16px 0;
    background: rgba(88,166,255,.05); border-radius: 0 8px 8px 0;
    color: var(--text-muted);
  }

  .article-footer {
    margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--border);
  }

</style>
