---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<Base
  title={`${post.data.title} — PicoClaw Blog`}
  description={post.data.description}
  canonical={`https://picoclaw.io/blog/${post.id}/`}
  lang={post.data.lang}
>
  <Nav active="blog" />

  <article class="blog-article">
    <header class="article-header">
      <a href="/blog/" class="back-link">&larr; Back to Blog</a>
      <h1 class="article-title reveal d1">{post.data.title}</h1>
      <div class="article-meta reveal d2">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        <span class="meta-sep">&middot;</span>
        <span>{post.data.author}</span>
      </div>
      <div class="article-tags reveal d2">
        {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </header>

    <div class="article-body reveal d3">
      <Content />
    </div>

    <footer class="article-footer">
      <a href="/blog/" class="back-link">&larr; Back to Blog</a>
    </footer>
  </article>

  <Footer />
</Base>

<style>
  .blog-article {
    position: relative; z-index: 1;
    max-width: 720px; margin: 0 auto; padding: 0 20px 60px;
  }

  .article-header { margin-bottom: 32px; }
  .back-link {
    display: inline-block; font-size: 0.82rem; color: var(--accent);
    text-decoration: none; margin-bottom: 20px;
  }
  .back-link:hover { text-decoration: underline; }

  .article-title {
    font-size: clamp(1.5rem, 4vw, 2.2rem); font-weight: 800;
    line-height: 1.3; color: var(--text); margin-bottom: 14px;
  }
  .article-meta {
    font-size: 0.82rem; color: var(--text-muted); margin-bottom: 12px;
    display: flex; align-items: center; gap: 8px;
  }
  .meta-sep { color: var(--border-h); }
  .article-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .tag {
    padding: 2px 8px; border-radius: 4px; font-size: 0.68rem;
    background: rgba(88,166,255,.1); color: var(--accent); border: 1px solid rgba(88,166,255,.2);
  }

  /* Article body — markdown content styling */
  .article-body {
    font-size: 0.95rem; line-height: 1.8; color: var(--text);
  }
  .article-body :global(h2) {
    font-size: 1.3rem; font-weight: 700; color: var(--text);
    margin: 40px 0 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border);
  }
  .article-body :global(h3) {
    font-size: 1.05rem; font-weight: 600; color: var(--text); margin: 28px 0 12px;
  }
  .article-body :global(p) { margin: 16px 0; }
  .article-body :global(img) { max-width: 100%; height: auto; border-radius: 10px; }
  .article-body :global(a) { color: var(--accent); text-decoration: none; }
  .article-body :global(a:hover) { text-decoration: underline; }
  .article-body :global(strong) { color: var(--text); font-weight: 600; }
  .article-body :global(ul), .article-body :global(ol) {
    padding-left: 24px; margin: 12px 0;
  }
  .article-body :global(li) { margin: 6px 0; }
  .article-body :global(code) {
    padding: 1px 6px; border-radius: 4px; background: rgba(0,0,0,.3);
    font-family: 'JetBrains Mono', monospace; font-size: 0.85em; color: var(--accent);
  }
  .article-body :global(pre) {
    background: rgba(0,0,0,.4); border: 1px solid var(--border); border-radius: 10px;
    padding: 16px 20px; margin: 16px 0; overflow-x: auto; font-size: 0.82rem;
    line-height: 1.6;
  }
  .article-body :global(pre code) {
    padding: 0; background: none; color: var(--text); font-size: inherit;
  }
  .article-body :global(blockquote) {
    border-left: 3px solid var(--accent); padding: 8px 16px; margin: 16px 0;
    background: rgba(88,166,255,.05); border-radius: 0 8px 8px 0;
    color: var(--text-muted);
  }

  .article-footer {
    margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--border);
  }

</style>
