---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Group by language
const enPosts = posts.filter(p => p.data.lang === 'en');
const zhPosts = posts.filter(p => p.data.lang === 'zh');

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<Base
  title="PicoClaw Blog — Tutorials, Guides & Updates"
  description="Tutorials, deployment guides, and updates for PicoClaw — the ultra-lightweight AI assistant. Learn how to run AI on Raspberry Pi, RISC-V, Android, and more."
  canonical="https://picoclaw.io/blog/"
>
  <Nav active="blog" />

  <header>
    <h1 class="page-title reveal d1">Blog</h1>
    <p class="page-desc reveal d2">Tutorials, guides, and updates for PicoClaw</p>
  </header>

  <main>
    <div class="posts-list" data-lang="en">
      {enPosts.length === 0 ? (
        <p class="empty">No posts yet. Stay tuned!</p>
      ) : (
        enPosts.map((post) => (
          <a href={`/blog/${post.id}/`} class="post-card reveal d3">
            <div class="post-meta">
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              <div class="post-tags">
                {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-desc">{post.data.description}</p>
          </a>
        ))
      )}
    </div>

    <div class="posts-list" data-lang="zh" style="display:none">
      {zhPosts.length === 0 ? (
        <p class="empty">暂无文章，敬请期待！</p>
      ) : (
        zhPosts.map((post) => (
          <a href={`/blog/${post.id}/`} class="post-card reveal d3">
            <div class="post-meta">
              <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString('zh-CN')}</time>
              <div class="post-tags">
                {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-desc">{post.data.description}</p>
          </a>
        ))
      )}
    </div>
  </main>

  <Footer />

  <script>
    document.addEventListener('astro:page-load', () => {
      if (window.location.pathname !== '/blog/') return;

      var saved = localStorage.getItem('lang');
      var lang = (saved === 'zh' || (!saved && navigator.language.startsWith('zh'))) ? 'zh' : 'en';

      function applyLang(l: string) {
        document.documentElement.lang = l === 'zh' ? 'zh-CN' : 'en';
        document.querySelectorAll<HTMLElement>('.posts-list[data-lang]').forEach(function(el) {
          el.style.display = el.dataset.lang === l ? '' : 'none';
        });
        var t = document.querySelector('.page-title');
        var d = document.querySelector('.page-desc');
        if (l === 'zh') {
          if (t) t.textContent = '博客';
          if (d) d.textContent = 'PicoClaw 教程、指南与更新';
        } else {
          if (t) t.textContent = 'Blog';
          if (d) d.textContent = 'Tutorials, guides, and updates for PicoClaw';
        }
        document.querySelectorAll<HTMLElement>('.lang-btn').forEach(function(btn) {
          btn.classList.toggle('active', btn.dataset.lang === l);
        });
      }

      applyLang(lang);

      window.addEventListener('lang-changed', function(e: any) {
        applyLang(e.detail.lang);
      });
    });
  </script>
</Base>

<style>
  header { position: relative; z-index: 1; text-align: center; padding: 20px 20px 40px; }
  .page-title { font-size: 1.6rem; font-weight: 700; color: var(--text); margin-bottom: 10px; }
  .page-desc { font-size: 0.92rem; color: var(--text-muted); max-width: 560px; margin: 0 auto; line-height: 1.6; }

  main { position: relative; z-index: 1; max-width: 760px; margin: 0 auto; padding: 0 20px 60px; }

  .posts-list { display: flex; flex-direction: column; gap: 16px; }
  .empty { text-align: center; color: var(--text-muted); padding: 40px 0; }

  .post-card {
    display: block; text-decoration: none; color: var(--text);
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px;
    padding: 24px; backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    transition: border-color .22s, background .22s, transform .22s;
  }
  .post-card:hover {
    border-color: var(--accent); background: var(--bg-card-h);
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,.2), 0 0 0 1px var(--accent);
  }

  .post-meta {
    display: flex; align-items: center; gap: 12px; margin-bottom: 10px; flex-wrap: wrap;
  }
  .post-meta time { font-size: 0.75rem; color: var(--text-muted); }
  .post-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .tag {
    padding: 2px 8px; border-radius: 4px; font-size: 0.68rem;
    background: rgba(88,166,255,.1); color: var(--accent); border: 1px solid rgba(88,166,255,.2);
  }

  .post-title { font-size: 1.1rem; font-weight: 600; margin-bottom: 8px; line-height: 1.4; }
  .post-desc { font-size: 0.84rem; color: var(--text-muted); line-height: 1.6; }

</style>
