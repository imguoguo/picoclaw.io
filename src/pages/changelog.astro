---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { releases as releasesEn } from '../data/changelog-en';
import { releases as releasesZh } from '../data/changelog-zh';

const GITHUB_BASE = 'https://github.com/sipeed/picoclaw/releases/tag/';
---
<Base
  title="PicoClaw Changelog — Release Notes & Version History"
  description="View PicoClaw release notes, version history, new features, bug fixes, and improvements. Stay up to date with the latest PicoClaw releases."
  canonical="https://picoclaw.io/changelog/"
>
  <Nav active="changelog" />

  <header>
    <h1 class="page-title reveal d1">Changelog</h1>
    <p class="page-desc reveal d2">Release notes and version history for PicoClaw</p>
  </header>

  <main>
    {/* English releases */}
    <div class="releases" data-lang="en">
      {releasesEn.map((r) => (
        <article class="release-card reveal d3" id={r.version}>
          <div class="release-header">
            <div class="release-meta">
              <h2 class="release-version"><a href={GITHUB_BASE + r.version} target="_blank" rel="noopener noreferrer">{r.version}</a></h2>
              <time class="release-date" datetime={r.date}>{new Date(r.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            </div>
            <a class="release-tag" href={GITHUB_BASE + r.version} target="_blank" rel="noopener noreferrer">{r.version}</a>
          </div>
          <div class="release-body">
            <ul>{r.highlights.map((h) => <li set:html={h} />)}</ul>
            {r.details.length > 0 && (
              <ul>{r.details.map((d) => <li set:html={d} />)}</ul>
            )}
          </div>
        </article>
      ))}
    </div>

    {/* Chinese releases */}
    <div class="releases" data-lang="zh" style="display:none">
      {releasesZh.map((r) => (
        <article class="release-card reveal d3">
          <div class="release-header">
            <div class="release-meta">
              <h2 class="release-version"><a href={GITHUB_BASE + r.version} target="_blank" rel="noopener noreferrer">{r.version}</a></h2>
              <time class="release-date" datetime={r.date}>{r.date}</time>
            </div>
            <a class="release-tag" href={GITHUB_BASE + r.version} target="_blank" rel="noopener noreferrer">{r.version}</a>
          </div>
          <div class="release-body">
            <ul>{r.highlights.map((h) => <li set:html={h} />)}</ul>
            {r.details.length > 0 && (
              <ul>{r.details.map((d) => <li set:html={d} />)}</ul>
            )}
          </div>
        </article>
      ))}
    </div>

    <div class="all-releases reveal d4">
      <a href="https://github.com/sipeed/picoclaw/releases" target="_blank" rel="noopener noreferrer" class="all-releases-link">
        View all releases on GitHub &rarr;
      </a>
    </div>
  </main>

  <Footer />

  <script>
    document.addEventListener('astro:page-load', () => {
      if (!window.location.pathname.startsWith('/changelog')) return;

      var saved = localStorage.getItem('lang');
      var lang = (saved === 'zh' || (!saved && navigator.language.startsWith('zh'))) ? 'zh' : 'en';

      function applyLang(l: string) {
        document.documentElement.lang = l === 'zh' ? 'zh-CN' : 'en';
        // Toggle release blocks
        document.querySelectorAll<HTMLElement>('.releases[data-lang]').forEach(function(el) {
          el.style.display = el.dataset.lang === l ? '' : 'none';
        });
        // Page text
        var title = document.querySelector('.page-title');
        var desc = document.querySelector('.page-desc');
        var allLink = document.querySelector('.all-releases-link');
        if (l === 'zh') {
          if (title) title.textContent = '更新日志';
          if (desc) desc.textContent = 'PicoClaw 版本发布记录与更新历史';
          if (allLink) allLink.innerHTML = '在 GitHub 上查看所有版本 →';
        } else {
          if (title) title.textContent = 'Changelog';
          if (desc) desc.textContent = 'Release notes and version history for PicoClaw';
          if (allLink) allLink.innerHTML = 'View all releases on GitHub →';
        }
        // Buttons
        document.querySelectorAll<HTMLElement>('.lang-btn').forEach(function(btn) {
          btn.classList.toggle('active', btn.dataset.lang === l);
        });
      }

      applyLang(lang);

      window.addEventListener('lang-changed', function(e: any) {
        applyLang(e.detail.lang);
      });
    });
  </script>
</Base>

<style>
  header {
    position: relative; z-index: 1; text-align: center; padding: 20px 20px 40px;
  }
  .page-title { font-size: 1.6rem; font-weight: 700; color: var(--text); margin-bottom: 10px; }
  .page-desc { font-size: 0.92rem; color: var(--text-muted); max-width: 560px; margin: 0 auto; line-height: 1.6; }

  main { position: relative; z-index: 1; max-width: 760px; margin: 0 auto; padding: 0 20px 60px; }

  .empty-state {
    text-align: center; padding: 60px 20px; color: var(--text-muted); font-size: 0.9rem;
  }
  .empty-state a { color: var(--accent); }

  .releases { display: flex; flex-direction: column; gap: 20px; }

  .release-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px;
    padding: 24px; backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    transition: border-color .22s, background .22s;
  }
  .release-card:hover { border-color: var(--border-h); background: var(--bg-card-h); }

  .release-header {
    display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;
    margin-bottom: 16px; flex-wrap: wrap;
  }
  .release-meta { flex: 1; min-width: 0; }
  .release-version { font-size: 1.1rem; font-weight: 600; margin-bottom: 4px; }
  .release-version a { color: var(--text); text-decoration: none; }
  .release-version a:hover { color: var(--accent); }
  .release-date { font-size: 0.78rem; color: var(--text-muted); }
  .release-tag {
    display: inline-flex; align-items: center; padding: 4px 10px; border-radius: 6px;
    background: rgba(88, 166, 255, 0.1); border: 1px solid rgba(88, 166, 255, 0.2);
    color: var(--accent); font-family: 'JetBrains Mono', monospace; font-size: 0.75rem;
    text-decoration: none; white-space: nowrap; transition: background .15s, border-color .15s;
  }
  .release-tag:hover { background: rgba(88, 166, 255, 0.2); border-color: rgba(88, 166, 255, 0.4); }

  .release-body {
    font-size: 0.85rem; color: var(--text-muted); line-height: 1.7;
    border-top: 1px solid var(--border); padding-top: 16px;
  }
  .release-body :global(h3) { font-size: 0.92rem; font-weight: 600; color: var(--text); margin: 16px 0 8px; }
  .release-body :global(h4) { font-size: 0.85rem; font-weight: 600; color: var(--text); margin: 12px 0 6px; }
  .release-body :global(ul) { list-style: none; padding: 0; margin: 8px 0; }
  .release-body :global(li) { padding: 3px 0 3px 16px; position: relative; }
  .release-body :global(li::before) { content: '\2022'; position: absolute; left: 0; color: var(--accent); }
  .release-body :global(a) { color: var(--accent); text-decoration: none; }
  .release-body :global(a:hover) { text-decoration: underline; }
  .release-body :global(code) {
    padding: 1px 5px; border-radius: 4px; background: rgba(0,0,0,.3);
    font-family: 'JetBrains Mono', monospace; font-size: 0.8em; color: var(--accent);
  }
  .release-body :global(strong) { color: var(--text); }
  .release-body :global(p) { margin: 8px 0; }

  .all-releases { text-align: center; margin-top: 32px; }
  .all-releases-link {
    display: inline-flex; align-items: center; padding: 10px 20px; border-radius: 8px;
    border: 1px solid var(--accent); background: transparent;
    color: var(--accent); font-size: 0.88rem; font-weight: 500;
    text-decoration: none; transition: background .15s, color .15s;
  }
  .all-releases-link:hover { background: var(--accent); color: #fff; }

</style>
