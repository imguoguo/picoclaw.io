---
import Base from '../layouts/Base.astro';
---
<Base
  title="Download PicoClaw for Linux, macOS, Windows, ARM64 & RISC-V"
  description="Download PicoClaw — ultra-lightweight AI assistant. Available for macOS (Apple Silicon & Intel), Windows, Linux (x86_64, ARM64, ARMv7, RISC-V, MIPS), FreeBSD, NetBSD, and Android. Single binary, no dependencies."
  canonical="https://picoclaw.io/download/"
>
  <nav class="top-nav">
    <a href="/" class="nav-brand">
      <img src="/icon.png" alt="" width="28" height="28" class="nav-logo" />
      <span>PicoClaw</span>
    </a>
    <div class="nav-links">
      <a href="/download/" class="nav-link active" data-i18n="nav-download">Download</a>
      <a href="/changelog/" class="nav-link" data-i18n="nav-changelog">Changelog</a>
      <a href="https://docs.picoclaw.io" target="_blank" rel="noopener noreferrer" class="nav-link" data-i18n="nav-docs">Docs</a>
    </div>
    <div class="lang-toggle" id="lang-toggle">
      <button class="lang-btn" data-lang="en">EN</button>
      <button class="lang-btn" data-lang="zh">中文</button>
    </div>
  </nav>

  <header>
    <h1 class="page-title reveal d1" data-i18n="dl-title">Download PicoClaw</h1>
    <p class="page-desc reveal d2" data-i18n="dl-desc">Choose your platform and architecture. Single binary, no dependencies — just download and run.</p>

    <div class="hero-dl reveal d2" id="hero-dl" style="display:none">
      <a class="hero-dl-btn" id="hero-dl-btn" href="#">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        <span id="hero-dl-label">Download</span>
      </a>
      <button class="hero-dl-expand" id="hero-dl-expand" aria-label="More download options">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </button>
    </div>
    <p class="hero-dl-sub reveal d2" id="hero-dl-sub" style="display:none"></p>
  </header>

  <main>
    <section aria-label="Platform downloads">
      <h2 class="section-label reveal d3" data-i18n="section-label">Choose your platform</h2>
      <div class="os-grid reveal d4" id="os-grid">
        <div class="state-msg" style="grid-column:1/-1" data-i18n="loading">Loading&hellip;</div>
      </div>
    </section>

    <section class="install-info" aria-label="Installation help">
      <h2 class="section-label" data-i18n="install-title">Quick Install</h2>
      <div class="install-grid">
        <article class="install-card">
          <h3 data-i18n="install-cli-title">CLI Setup</h3>
          <p data-i18n="install-cli-desc">After downloading, run the onboard command to initialize your workspace:</p>
          <code>picoclaw onboard</code>
        </article>
        <article class="install-card">
          <h3 data-i18n="install-docs-title">Full Guide</h3>
          <p data-i18n="install-docs-desc">For detailed installation instructions, Docker setup, and Android/Termux support:</p>
          <a class="install-link" href="https://docs.picoclaw.io/docs/getting-started/" target="_blank" rel="noopener noreferrer" data-i18n="install-docs-link">Read Installation Guide &rarr;</a>
        </article>
      </div>
    </section>
  </main>

  <!-- Download Modal -->
  <div class="backdrop" id="backdrop" role="presentation">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title-text">
      <div class="modal-head">
        <img class="modal-icon" id="modal-icon" src="" alt="" width="34" height="34" />
        <div class="modal-titles">
          <div class="modal-title" id="modal-title-text"></div>
          <div class="modal-sub" data-i18n="modal-sub">Select architecture to download</div>
        </div>
        <button class="close-btn" id="close-btn" aria-label="Close">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <div class="divider"></div>
      <div class="arch-list" id="arch-list"></div>
      <div class="modal-foot">
        <span class="modal-foot-note" data-i18n="modal-foot-note">Always downloads the latest release</span>
        <a class="chk-link" id="checksums-link" href="#" target="_blank" rel="noopener noreferrer">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span data-i18n="checksums">SHA256 Checksums</span>
        </a>
      </div>
      <div class="source-toggle">
        <span class="source-label" data-i18n="source-label">Download source:</span>
        <div class="source-btns" id="source-btns">
          <button class="source-btn" data-source="github">GitHub</button>
          <button class="source-btn" data-source="cdn">Sipeed CDN</button>
        </div>
      </div>
    </div>
  </div>

  <footer>
    <nav class="footer-links" aria-label="Footer links">
      <a href="/">Home</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="https://github.com/sipeed/picoclaw" target="_blank" rel="noopener noreferrer">GitHub</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="https://docs.picoclaw.io" target="_blank" rel="noopener noreferrer" data-i18n="footer-docs">Docs</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="/changelog/" data-i18n="footer-changelog">Changelog</a>
    </nav>
    <div id="footer-credit">PicoClaw is open-source software by <a href="https://github.com/sipeed" target="_blank" rel="noopener noreferrer">Sipeed</a></div>
  </footer>

  <script is:inline>
    // ── i18n (download page) ─────────────────────────────────────
    var TRANSLATIONS = {
      en: {
        'dl-title':             'Download PicoClaw',
        'dl-desc':              'Choose your platform and architecture. Single binary, no dependencies \u2014 just download and run.',
        'section-label':        'Choose your platform',
        'loading':              'Loading\u2026',
        'modal-sub':            'Select architecture to download',
        'modal-foot-note':      'Always downloads the latest release',
        'checksums':            'SHA256 Checksums',
        'source-label':         'Download source:',
        'footer-docs':          'Docs',
        'footer-changelog':     'Changelog',
        'arch-count':           function(n) { return n + ' architecture' + (n > 1 ? 's' : ''); },
        'hero-dl-for':          function(os, arch) { return 'Download for ' + os + ' (' + arch + ')'; },
        'hero-dl-other':        'Other platforms',
        'install-title':        'Quick Install',
        'install-cli-title':    'CLI Setup',
        'install-cli-desc':     'After downloading, run the onboard command to initialize your workspace:',
        'install-docs-title':   'Full Guide',
        'install-docs-desc':    'For detailed installation instructions, Docker setup, and Android/Termux support:',
        'install-docs-link':    'Read Installation Guide \u2192',
        'nav-download':         'Download',
        'nav-changelog':        'Changelog',
        'nav-docs':             'Docs',
      },
      zh: {
        'dl-title':             '\u4e0b\u8f7d PicoClaw',
        'dl-desc':              '\u9009\u62e9\u4f60\u7684\u5e73\u53f0\u548c\u67b6\u6784\u3002\u5355\u4e00\u4e8c\u8fdb\u5236\uff0c\u65e0\u4f9d\u8d56\u2014\u2014\u4e0b\u8f7d\u5373\u7528\u3002',
        'section-label':        '\u9009\u62e9\u5e73\u53f0',
        'loading':              '\u52a0\u8f7d\u4e2d\u2026',
        'modal-sub':            '\u9009\u62e9\u67b6\u6784\u4ee5\u4e0b\u8f7d',
        'modal-foot-note':      '\u59cb\u7ec8\u4e0b\u8f7d\u6700\u65b0\u7248\u672c',
        'checksums':            'SHA256 \u6821\u9a8c\u548c',
        'source-label':         '\u4e0b\u8f7d\u6e90\uff1a',
        'footer-docs':          '\u6587\u6863',
        'footer-changelog':     '\u66f4\u65b0\u65e5\u5fd7',
        'arch-count':           function(n) { return n + ' \u4e2a\u67b6\u6784'; },
        'hero-dl-for':          function(os, arch) { return '\u4e0b\u8f7d ' + os + ' (' + arch + ') \u7248'; },
        'hero-dl-other':        '\u5176\u4ed6\u5e73\u53f0',
        'install-title':        '\u5feb\u901f\u5b89\u88c5',
        'install-cli-title':    'CLI \u521d\u59cb\u5316',
        'install-cli-desc':     '\u4e0b\u8f7d\u540e\uff0c\u8fd0\u884c onboard \u547d\u4ee4\u521d\u59cb\u5316\u5de5\u4f5c\u533a\uff1a',
        'install-docs-title':   '\u5b8c\u6574\u6307\u5357',
        'install-docs-desc':    '\u8be6\u7ec6\u7684\u5b89\u88c5\u8bf4\u660e\u3001Docker \u90e8\u7f72\u548c Android/Termux \u652f\u6301\uff1a',
        'install-docs-link':    '\u9605\u8bfb\u5b89\u88c5\u6307\u5357 \u2192',
        'nav-download':         '\u4e0b\u8f7d',
        'nav-changelog':        '\u66f4\u65b0\u65e5\u5fd7',
        'nav-docs':             '\u6587\u6863',
      },
    };

    function detectLang() {
      var saved = localStorage.getItem('lang');
      if (saved && TRANSLATIONS[saved]) return saved;
      return navigator.language.startsWith('zh') ? 'zh' : 'en';
    }
    var currentLang = detectLang();
    function t(key) {
      return (TRANSLATIONS[currentLang] || TRANSLATIONS.en)[key] || TRANSLATIONS.en[key] || key;
    }
    function applyStaticLang() {
      document.documentElement.lang = currentLang === 'zh' ? 'zh-CN' : 'en';
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var val = t(el.dataset.i18n);
        if (typeof val === 'string' && val.indexOf('<') !== -1) el.innerHTML = val;
        else if (typeof val === 'string') el.textContent = val;
      });
      document.querySelectorAll('.lang-btn').forEach(function(btn) {
        btn.classList.toggle('active', btn.dataset.lang === currentLang);
      });
    }
    function switchLang(lang) {
      currentLang = lang;
      currentSource = lang === 'zh' ? 'cdn' : 'github';
      localStorage.setItem('lang', lang);
      applyStaticLang();
      if (platformData) buildCards(platformData);
    }
    document.getElementById('lang-toggle').addEventListener('click', function(e) {
      var btn = e.target.closest('.lang-btn');
      if (btn) switchLang(btn.dataset.lang);
    });

    // ── Platform data & download logic (same as homepage) ────────
    var PLATFORMS = [
      { id: 'macos', name: 'macOS', icon: 'apple', color: '#b0b0b5', archs: [
        { label: 'Apple Silicon (arm64)', desc: 'M1 / M2 / M3 and later', file: 'picoclaw_Darwin_arm64.tar.gz' },
        { label: 'Intel (x86_64)', desc: 'Intel-based Mac', file: 'picoclaw_Darwin_x86_64.tar.gz' },
      ]},
      { id: 'windows', name: 'Windows', icon: 'windows', color: '#0a84ff', archs: [
        { label: 'x86_64 (64-bit)', desc: 'Recommended for most PCs', file: 'picoclaw_Windows_x86_64.zip' },
        { label: 'ARM64', desc: 'Windows on ARM', file: 'picoclaw_Windows_arm64.zip' },
      ]},
      { id: 'linux', name: 'Linux', icon: 'linux', color: '#f5a623', archs: [
        { label: 'x86_64', desc: '64-bit \u00b7 Recommended', file: 'picoclaw_Linux_x86_64.tar.gz', packages: { deb: 'picoclaw_x86_64.deb', rpm: 'picoclaw_x86_64.rpm' } },
        { label: 'ARM64 (arm64)', desc: 'Raspberry Pi 4/5, modern SBCs', file: 'picoclaw_Linux_arm64.tar.gz', packages: { deb: 'picoclaw_aarch64.deb', rpm: 'picoclaw_aarch64.rpm' } },
        { label: 'ARMv7 (armv7)', desc: 'Raspberry Pi 2/3, older SBCs', file: 'picoclaw_Linux_armv7.tar.gz', packages: { deb: 'picoclaw_armv7.deb', rpm: 'picoclaw_armv7.rpm' } },
        { label: 'ARMv6 (armv6)', desc: 'Raspberry Pi 1 / Zero', file: 'picoclaw_Linux_armv6.tar.gz', packages: { deb: 'picoclaw_armv6.deb', rpm: 'picoclaw_armv6.rpm' } },
        { label: 'RISC-V 64 (riscv64)', desc: 'RISC-V 64-bit', file: 'picoclaw_Linux_riscv64.tar.gz', packages: { deb: 'picoclaw_riscv64.deb', rpm: 'picoclaw_riscv64.rpm' } },
        { label: 'MIPS (mipsle)', desc: 'MIPS little-endian 32-bit', file: 'picoclaw_Linux_mipsle.tar.gz', packages: { deb: 'picoclaw_mipsle.deb', rpm: 'picoclaw_mipsle.rpm' } },
        { label: 's390x', desc: 'IBM Z / LinuxONE', file: 'picoclaw_Linux_s390x.tar.gz', packages: { deb: 'picoclaw_s390x.deb', rpm: 'picoclaw_s390x.rpm' } },
      ]},
      { id: 'freebsd', name: 'FreeBSD', icon: 'freebsd', color: '#d03030', archs: [
        { label: 'x86_64', desc: '64-bit \u00b7 Recommended', file: 'picoclaw_Freebsd_x86_64.tar.gz' },
        { label: 'ARM64 (arm64)', desc: 'AArch64', file: 'picoclaw_Freebsd_arm64.tar.gz' },
        { label: 'ARMv7 (armv7)', desc: 'ARM 32-bit', file: 'picoclaw_Freebsd_armv7.tar.gz' },
      ]},
      { id: 'netbsd', name: 'NetBSD', icon: 'netbsd', color: '#FF6600', archs: [
        { label: 'x86_64', desc: '64-bit \u00b7 Recommended', file: 'picoclaw_Netbsd_x86_64.tar.gz' },
        { label: 'ARM64 (arm64)', desc: 'AArch64', file: 'picoclaw_Netbsd_arm64.tar.gz' },
      ]},
      { id: 'android', name: 'Android', icon: 'android', color: '#3ddc84',
        link: 'https://docs.picoclaw.io/docs/getting-started#run-on-android-termux',
        sub: { en: 'View Guide', zh: '\u67e5\u770b\u6559\u7a0b' },
      },
      { id: 'docker', name: 'Docker', icon: 'docker', color: '#2496ed',
        link: 'https://docs.picoclaw.io/docs/docker',
        sub: { en: 'View Guide', zh: '\u67e5\u770b\u6559\u7a0b' },
      },
    ];

    var BASE_DL_GITHUB = 'https://github.com/sipeed/picoclaw/releases/latest/download/';
    var BASE_DL_CDN = 'https://picoclaw-downloads.tos-cn-beijing.volces.com/latest/';
    var RELEASES_URL = 'https://github.com/sipeed/picoclaw/releases/latest';
    var currentSource = currentLang === 'zh' ? 'cdn' : 'github';

    function getBaseDL() { return currentSource === 'cdn' ? BASE_DL_CDN : BASE_DL_GITHUB; }
    var ICON_CDN = 'https://cdn.simpleicons.org/';
    var INLINE_ICONS = {
      windows: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="{COLOR}"><path d="M3 5L10.5 3.9V11H3zM11.5 3.7L21 2.5V11H11.5zM3 12H10.5V20.1L3 19zM11.5 12H21V21.5L11.5 20.3z"/></svg>',
    };
    function iconUrl(slug, color) {
      if (INLINE_ICONS[slug]) return 'data:image/svg+xml;utf8,' + encodeURIComponent(INLINE_ICONS[slug].replace('{COLOR}', color));
      return ICON_CDN + slug + '/' + color.replace('#', '');
    }

    var ARROW_SVG = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
    var DL_SVG = '<svg class="dl-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>';

    var platformData = null;
    function buildCards(platforms) {
      platformData = platforms;
      var grid = document.getElementById('os-grid');
      grid.innerHTML = '';
      platforms.forEach(function(p) {
        var card = document.createElement('div');
        card.className = 'os-card';
        card.style.setProperty('--c', p.color);
        card.setAttribute('role', 'button');
        card.setAttribute('tabindex', '0');
        var subText = p.sub ? (p.sub[currentLang] || p.sub.en) : t('arch-count')(p.archs.length);
        card.innerHTML = '<img class="os-icon" src="' + iconUrl(p.icon, p.color) + '" alt="Download PicoClaw for ' + p.name + '" width="54" height="54" /><div class="os-info"><div class="os-name">' + p.name + '</div><div class="os-sub">' + subText + '</div></div><div class="os-arrow">' + ARROW_SVG + '</div>';
        var action = p.link ? function() { window.open(p.link, '_blank', 'noopener,noreferrer'); } : (function(pl) { return function() { openModal(pl); }; })(p);
        card.addEventListener('click', action);
        card.addEventListener('keydown', function(e) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); action(); } });
        grid.appendChild(card);
      });
    }

    var currentModalPlatform = null;
    function renderArchList(p) {
      var base = getBaseDL();
      var list = document.getElementById('arch-list');
      list.innerHTML = '';
      p.archs.forEach(function(arch) {
        var el;
        if (arch.packages) {
          el = document.createElement('div');
          el.className = 'arch-item arch-item--multi';
          el.innerHTML = '<div class="arch-left"><span class="arch-label">' + arch.label + '</span><span class="arch-file">' + arch.desc + '</span></div><div class="arch-right"><a class="fmt-btn" href="' + base + arch.file + '" target="_blank" rel="noopener noreferrer">.tar.gz</a><a class="fmt-btn" href="' + base + arch.packages.deb + '" target="_blank" rel="noopener noreferrer">.deb</a><a class="fmt-btn" href="' + base + arch.packages.rpm + '" target="_blank" rel="noopener noreferrer">.rpm</a></div>';
        } else {
          el = document.createElement('a');
          el.className = 'arch-item';
          el.href = base + arch.file;
          el.target = '_blank';
          el.rel = 'noopener noreferrer';
          el.innerHTML = '<div class="arch-left"><span class="arch-label">' + arch.label + '</span><span class="arch-file">' + arch.file + '</span></div><div class="arch-right">' + DL_SVG + '</div>';
        }
        list.appendChild(el);
      });
    }
    function updateSourceBtns() {
      document.querySelectorAll('#source-btns .source-btn').forEach(function(btn) {
        btn.classList.toggle('active', btn.dataset.source === currentSource);
      });
    }
    function openModal(p) {
      currentModalPlatform = p;
      document.getElementById('modal-title-text').textContent = p.name;
      document.getElementById('modal-icon').src = iconUrl(p.icon, p.color);
      document.getElementById('modal-icon').alt = p.name;
      renderArchList(p);
      updateSourceBtns();
      document.getElementById('backdrop').classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeModal() {
      document.getElementById('backdrop').classList.remove('open');
      document.body.style.overflow = '';
    }
    document.getElementById('backdrop').addEventListener('click', function(e) { if (e.target === e.currentTarget) closeModal(); });
    document.getElementById('close-btn').addEventListener('click', closeModal);
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });
    document.getElementById('source-btns').addEventListener('click', function(e) {
      var btn = e.target.closest('.source-btn');
      if (!btn) return;
      currentSource = btn.dataset.source;
      updateSourceBtns();
      if (currentModalPlatform) renderArchList(currentModalPlatform);
    });

    // ── Platform detection ───────────────────────────────────────
    function detectPlatformSync() {
      var ua = navigator.userAgent, platform = navigator.platform || '', os = null, arch = null;
      if (/Macintosh|Mac OS X/.test(ua)) { os = 'macos'; arch = 'arm64'; }
      else if (/Windows/.test(ua)) { os = 'windows'; arch = 'x86_64'; if (/ARM|WOA/.test(ua)) arch = 'arm64'; }
      else if (/Android/.test(ua)) { os = 'android'; }
      else if (/Linux/.test(ua)) { os = 'linux'; arch = 'x86_64'; if (/aarch64|arm64/.test(platform)) arch = 'arm64'; else if (/armv7/.test(platform)) arch = 'armv7'; }
      else if (/FreeBSD/.test(ua)) { os = 'freebsd'; arch = 'x86_64'; if (/aarch64|arm64/.test(platform)) arch = 'arm64'; }
      return { os: os, arch: arch };
    }
    var detectedPlatform = detectPlatformSync();
    if (navigator.userAgentData && navigator.userAgentData.getHighEntropyValues) {
      navigator.userAgentData.getHighEntropyValues(['architecture', 'platform']).then(function(hints) {
        var a = (hints.architecture || '').toLowerCase();
        if (detectedPlatform.os === 'macos') detectedPlatform.arch = a === 'arm' ? 'arm64' : 'x86_64';
        else if (detectedPlatform.os === 'windows') detectedPlatform.arch = a === 'arm' ? 'arm64' : 'x86_64';
        updateHero();
      }).catch(function() {});
    }
    function findMatch(os, arch) {
      var p = PLATFORMS.find(function(p) { return p.id === os; });
      if (!p || !p.archs) return null;
      var a = p.archs.find(function(a) { return a.file.toLowerCase().indexOf(arch) !== -1; });
      return a ? { platform: p, arch: a } : null;
    }
    function setupHero() {
      var d = detectedPlatform;
      if (!d.os || d.os === 'android') return;
      var m = findMatch(d.os, d.arch);
      if (!m) return;
      document.getElementById('hero-dl-label').textContent = t('hero-dl-for')(m.platform.name, d.arch);
      document.getElementById('hero-dl-btn').href = getBaseDL() + m.arch.file;
      document.getElementById('hero-dl-btn').target = '_blank';
      document.getElementById('hero-dl-sub').innerHTML = m.arch.file + ' \u00b7 <a href="#os-grid">' + t('hero-dl-other') + '</a>';
      document.getElementById('hero-dl').style.display = '';
      document.getElementById('hero-dl-sub').style.display = '';
      document.getElementById('hero-dl-expand').addEventListener('click', function() { openModal(m.platform); });
    }
    function updateHero() {
      var d = detectedPlatform, m = findMatch(d.os, d.arch);
      if (!m) return;
      document.getElementById('hero-dl-label').textContent = t('hero-dl-for')(m.platform.name, d.arch);
      document.getElementById('hero-dl-btn').href = getBaseDL() + m.arch.file;
      document.getElementById('hero-dl-sub').innerHTML = m.arch.file + ' \u00b7 <a href="#os-grid">' + t('hero-dl-other') + '</a>';
