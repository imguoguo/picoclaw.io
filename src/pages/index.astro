---
import Base from '../layouts/Base.astro';
---
<Base>
  <nav class="top-nav">
    <a href="/" class="nav-brand">
      <img src="/icon.png" alt="" width="28" height="28" class="nav-logo" />
      <span>PicoClaw</span>
    </a>
    <div class="nav-links">
      <a href="/download/" class="nav-link" data-i18n="nav-download">Download</a>
      <a href="/changelog/" class="nav-link" data-i18n="nav-changelog">Changelog</a>
      <a href="https://docs.picoclaw.io" target="_blank" rel="noopener noreferrer" class="nav-link" data-i18n="nav-docs">Docs</a>
      <a href="https://github.com/sipeed/picoclaw" target="_blank" rel="noopener noreferrer" class="nav-link">GitHub</a>
    </div>
    <div class="lang-toggle" id="lang-toggle">
      <button class="lang-btn" data-lang="en">EN</button>
      <button class="lang-btn" data-lang="zh">中文</button>
    </div>
  </nav>

  <header>
    <div class="hero-content">
      <div class="logo-wrap reveal d1">
        <img src="/logo.webp" alt="PicoClaw — Ultra-lightweight AI assistant for Raspberry Pi, RISC-V and Linux" width="160" height="160" />
      </div>

      <h1 class="hero-headline reveal d1" data-i18n="hero-headline">Ultra-Lightweight AI Assistant<br/>Written in Go</h1>
      <p class="hero-sub reveal d2" data-i18n="hero-sub">Single binary &middot; &lt;10MB RAM &middot; 1s startup &middot; Runs on $10 hardware</p>

      <div class="hero-cta reveal d3">
        <a class="hero-dl-btn" href="/download/">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          <span data-i18n="hero-dl-btn">Download PicoClaw</span>
        </a>
        <a class="hero-gh-btn" href="https://github.com/sipeed/picoclaw" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          <span data-i18n="hero-gh-btn">View on GitHub</span>
        </a>
      </div>

      <div class="hero-badges reveal d3">
        <a class="badge-link" href="https://github.com/sipeed/picoclaw/releases/latest" target="_blank" rel="noopener noreferrer">
          <img src="https://img.shields.io/github/v/release/sipeed/picoclaw?style=flat-square&logo=github&color=58a6ff&labelColor=0d1117&logoColor=white" alt="Latest Release" height="24" width="auto" loading="lazy" />
        </a>
        <a class="badge-link" href="https://github.com/sipeed/picoclaw" target="_blank" rel="noopener noreferrer">
          <img src="https://img.shields.io/github/stars/sipeed/picoclaw?style=flat-square&logo=github&color=f5a623&labelColor=0d1117&logoColor=white" alt="GitHub Stars" height="24" width="auto" loading="lazy" />
        </a>
        <a class="badge-link" href="https://raw.githubusercontent.com/sipeed/picoclaw/main/assets/wechat.png" target="_blank" rel="noopener noreferrer">
          <img src="https://img.shields.io/badge/WeChat-Group-41d56b?style=flat-square&logo=wechat&logoColor=white" alt="WeChat Group" height="24" width="auto" loading="lazy" />
        </a>
        <a class="badge-link" href="https://discord.gg/V4sAZ9XWpN" target="_blank" rel="noopener noreferrer">
          <img src="https://img.shields.io/badge/Discord-Community-4c60eb?style=flat-square&logo=discord&logoColor=white" alt="Discord" height="24" width="auto" loading="lazy" />
        </a>
      </div>

      <!-- Stats bar -->
      <div class="hero-stats reveal d4">
        <div class="stat-item">
          <span class="stat-value">&lt;10MB</span>
          <span class="stat-label" data-i18n="stat-mem">Memory</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-item">
          <span class="stat-value">&lt;1s</span>
          <span class="stat-label" data-i18n="stat-boot">Boot Time</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-item">
          <span class="stat-value">9+</span>
          <span class="stat-label" data-i18n="stat-channels">Channels</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-item">
          <span class="stat-value">$10</span>
          <span class="stat-label" data-i18n="stat-hw">Min Hardware</span>
        </div>
      </div>
    </div>
  </header>

  <!-- Product Landing Section -->
  <section class="product-section" aria-label="What is PicoClaw">
    <div class="product-intro reveal d3">
      <h2 data-i18n="product-title">What is PicoClaw?</h2>
      <p data-i18n="product-desc">PicoClaw is an ultra-lightweight personal AI assistant written in Go. Deploy a single binary on any device — from a $10 Raspberry Pi to a cloud server — and get a fully functional AI assistant with less than 10MB of RAM and under 1 second startup time. 99% smaller and 400x faster than comparable solutions.</p>
    </div>

    <div class="features-grid">
      <div class="feature-card reveal d3">
        <div class="feature-icon">&#9889;</div>
        <h3 data-i18n="feat-lightweight">Ultra-Lightweight</h3>
        <p data-i18n="feat-lightweight-desc">&lt;10MB RAM footprint. Single self-contained binary with zero external dependencies. Runs on $10 hardware.</p>
      </div>
      <div class="feature-card reveal d3">
        <div class="feature-icon">&#128640;</div>
        <h3 data-i18n="feat-fast">400x Faster Startup</h3>
        <p data-i18n="feat-fast-desc">Boots in under 1 second even on a 0.6GHz single-core processor. Written in Go for maximum efficiency.</p>
      </div>
      <div class="feature-card reveal d3">
        <div class="feature-icon">&#127760;</div>
        <h3 data-i18n="feat-platforms">Run Anywhere</h3>
        <p data-i18n="feat-platforms-desc">Raspberry Pi, RISC-V, ARM64, x86_64, Android via Termux, Docker — one binary covers all platforms.</p>
      </div>
      <div class="feature-card reveal d3">
        <div class="feature-icon">&#128172;</div>
        <h3 data-i18n="feat-channels">9+ Chat Channels</h3>
        <p data-i18n="feat-channels-desc">Telegram, Discord, Slack, DingTalk, Feishu, WeCom, LINE, QQ and more. Connect your AI to any platform.</p>
      </div>
      <div class="feature-card reveal d3">
        <div class="feature-icon">&#129302;</div>
        <h3 data-i18n="feat-llm">Multi-LLM Support</h3>
        <p data-i18n="feat-llm-desc">OpenAI, Claude, DeepSeek, Doubao and more. Switch providers freely with a single config change.</p>
      </div>
      <div class="feature-card reveal d3">
        <div class="feature-icon">&#128274;</div>
        <h3 data-i18n="feat-selfhost">Self-Hosted &amp; Private</h3>
        <p data-i18n="feat-selfhost-desc">Your data stays on your device. No cloud dependency. Full control over your AI assistant.</p>
      </div>
    </div>

    <!-- Internal links to docs (SEO anchor text) -->
    <nav class="docs-links reveal d4" aria-label="Documentation links">
      <h3 data-i18n="docs-links-title">Learn More</h3>
      <div class="docs-links-grid">
        <a href="https://docs.picoclaw.io/docs/getting-started/" target="_blank" rel="noopener noreferrer" data-i18n="link-install">Installation Guide</a>
        <a href="https://docs.picoclaw.io/docs/getting-started/supported-providers/" target="_blank" rel="noopener noreferrer" data-i18n="link-providers">Supported LLM Providers</a>
        <a href="https://docs.picoclaw.io/docs/getting-started/supported-channels/" target="_blank" rel="noopener noreferrer" data-i18n="link-channels">Supported Chat Channels</a>
        <a href="https://docs.picoclaw.io/docs/guides/run-on-android/" target="_blank" rel="noopener noreferrer" data-i18n="link-android">Run on Android / Termux</a>
        <a href="https://docs.picoclaw.io/docs/guides/docker/" target="_blank" rel="noopener noreferrer" data-i18n="link-docker">Docker Deployment</a>
        <a href="https://docs.picoclaw.io/docs/guides/security/" target="_blank" rel="noopener noreferrer" data-i18n="link-security">Security &amp; Sandbox</a>
      </div>
    </nav>
  </section>

  <!-- Comparison Section -->
  <section class="comparison-section" aria-label="Performance comparison">
    <div class="comparison-inner">
      <h2 class="section-heading reveal d3" data-i18n="cmp-title">PicoClaw vs Alternatives</h2>
      <p class="section-desc reveal d3" data-i18n="cmp-desc">Rewritten in Go for 10x performance. See how PicoClaw compares.</p>
      <div class="comparison-table-wrap reveal d4">
        <table class="comparison-table">
          <thead>
            <tr>
              <th data-i18n="cmp-metric">Metric</th>
              <th>OpenClaw</th>
              <th>NanoBot</th>
              <th class="highlight">PicoClaw</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td data-i18n="cmp-memory">Memory Usage</td>
              <td>&gt;100MB</td>
              <td>&gt;100MB</td>
              <td class="highlight" data-i18n="cmp-memory-val">&lt;10MB</td>
            </tr>
            <tr>
              <td data-i18n="cmp-startup">Startup Time</td>
              <td>&gt;30s</td>
              <td>&gt;30s</td>
              <td class="highlight">&lt;1s</td>
            </tr>
            <tr>
              <td data-i18n="cmp-arch">Architectures</td>
              <td>x86_64, ARM64</td>
              <td>x86_64, ARM64</td>
              <td class="highlight" data-i18n="cmp-arch-val">x86, ARM, RISC-V, MIPS</td>
            </tr>
            <tr>
              <td data-i18n="cmp-cost">Min Hardware Cost</td>
              <td>~$50</td>
              <td>~$50</td>
              <td class="highlight">~$10</td>
            </tr>
            <tr>
              <td data-i18n="cmp-channels">Chat Channels</td>
              <td>WhatsApp</td>
              <td data-i18n="cmp-limited">Limited</td>
              <td class="highlight" data-i18n="cmp-channels-val">9+ (TG, Discord, QQ, DingTalk...)</td>
            </tr>
            <tr>
              <td data-i18n="cmp-privacy">Data Privacy</td>
              <td data-i18n="cmp-cloud">Cloud-dependent</td>
              <td data-i18n="cmp-cloud">Cloud-dependent</td>
              <td class="highlight" data-i18n="cmp-local">100% Local</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Use Cases Section -->
  <section class="usecases-section" aria-label="Use cases">
    <div class="usecases-inner">
      <h2 class="section-heading reveal d3" data-i18n="uc-title">Built for Real-World Applications</h2>
      <p class="section-desc reveal d3" data-i18n="uc-desc">From personal productivity to professional workflows, PicoClaw adapts to your needs.</p>
      <div class="usecases-grid">
        <article class="usecase-card reveal d3">
          <div class="usecase-icon">&#128187;</div>
          <h3 data-i18n="uc-code">Code Assistant</h3>
          <p data-i18n="uc-code-desc">Local code completion, debugging, and documentation generation. Keep proprietary code private while getting AI assistance.</p>
        </article>
        <article class="usecase-card reveal d3">
          <div class="usecase-icon">&#9997;&#65039;</div>
          <h3 data-i18n="uc-content">Content Creation</h3>
          <p data-i18n="uc-content-desc">Write blog posts, emails, and documents with AI. All drafts and ideas stay on your device, fully private.</p>
        </article>
        <article class="usecase-card reveal d3">
          <div class="usecase-icon">&#128202;</div>
          <h3 data-i18n="uc-data">Data Analysis</h3>
          <p data-i18n="uc-data-desc">Analyze sensitive business data locally. No data leaves your infrastructure, ensuring complete confidentiality.</p>
        </article>
        <article class="usecase-card reveal d3">
          <div class="usecase-icon">&#128197;</div>
          <h3 data-i18n="uc-assistant">Personal Assistant</h3>
          <p data-i18n="uc-assistant-desc">Manage tasks with scheduled commands, cron automation, and multi-platform bot integration in your daily workflow.</p>
        </article>
        <article class="usecase-card reveal d3">
          <div class="usecase-icon">&#128218;</div>
          <h3 data-i18n="uc-research">Research &amp; Learning</h3>
          <p data-i18n="uc-research-desc">Summarize papers, answer questions, and organize knowledge. Built-in web search and long-term memory for context continuity.</p>
        </article>
        <article class="usecase-card reveal d3">
          <div class="usecase-icon">&#128268;</div>
          <h3 data-i18n="uc-api">API &amp; Integration</h3>
          <p data-i18n="uc-api-desc">Gateway mode turns PicoClaw into an AI backend. Connect any chat platform via MCP protocol and REST API.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section" aria-label="FAQ">
    <div class="faq-inner">
      <h2 class="section-heading reveal d3" data-i18n="faq-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <details class="faq-item reveal d3">
          <summary data-i18n="faq-q1">What is PicoClaw?</summary>
          <p data-i18n="faq-a1">PicoClaw is an ultra-lightweight personal AI assistant written in Go. It deploys as a single binary with less than 10MB memory usage, supports 9+ chat platforms (Telegram, Discord, Slack, QQ, DingTalk, etc.), and runs on everything from a $10 Raspberry Pi to cloud servers.</p>
        </details>
        <details class="faq-item reveal d3">
          <summary data-i18n="faq-q2">How is PicoClaw different from ChatGPT or other AI assistants?</summary>
          <p data-i18n="faq-a2">PicoClaw is self-hosted — your data stays on your device. It connects to LLM providers (OpenAI, Claude, DeepSeek, etc.) via API, but all conversation history and configuration remain local. It's also designed for ultra-low resource environments that cloud-based solutions can't serve.</p>
        </details>
        <details class="faq-item reveal d3">
          <summary data-i18n="faq-q3">What hardware do I need to run PicoClaw?</summary>
          <p data-i18n="faq-a3">Minimum: any device with 64MB RAM and an internet connection for LLM API calls. Recommended: 512MB RAM. PicoClaw runs on x86_64, ARM64, ARMv7, ARMv6, RISC-V, and MIPS architectures. A $10 Raspberry Pi Zero works perfectly.</p>
        </details>
        <details class="faq-item reveal d3">
          <summary data-i18n="faq-q4">Which LLM providers does PicoClaw support?</summary>
          <p data-i18n="faq-a4">OpenAI (GPT-4o, o1), Anthropic (Claude), DeepSeek, Google Gemini, Mistral, Volcengine (Doubao), Qwen, Minimax, Moonshot (Kimi), Cerebras, Perplexity, Ollama (local), and any OpenAI-compatible API.</p>
        </details>
        <details class="faq-item reveal d3">
          <summary data-i18n="faq-q5">Can I run PicoClaw on my phone?</summary>
          <p data-i18n="faq-a5">Yes! PicoClaw runs on Android via Termux. Download the ARM64 binary, install it in Termux, and you have a full AI assistant on your phone. See the <a href="https://docs.picoclaw.io/docs/getting-started#run-on-android-termux">Android guide</a> for details.</p>
        </details>
        <details class="faq-item reveal d3">
          <summary data-i18n="faq-q6">Is PicoClaw free and open source?</summary>
          <p data-i18n="faq-a6">Yes, PicoClaw is fully open source under the MIT-compatible license. The software is free. You only pay for the LLM API usage (e.g., OpenAI, Claude) based on your own consumption.</p>
        </details>
      </div>
    </div>
  </section>

  <main>
    <section class="subscribe-section" aria-label="Stay connected">
      <h2 class="section-label" data-i18n="subscribe-title">Stay Connected</h2>
      <p style="color:var(--text-muted);font-size:0.9rem;" data-i18n="subscribe-desc">Subscribe for news and product updates.</p>
      <div class="form-grid">
        <article class="form-card">
          <h3 data-i18n="subscribe-global">Global &middot; Google Form</h3>
          <p data-i18n="subscribe-global-desc">International users can subscribe via Google Forms.</p>
          <a class="form-link" href="https://forms.gle/2CP5WkkFu3KLFKy89" target="_blank" rel="noopener noreferrer" data-i18n="subscribe-btn-google">Subscribe via Google Form</a>
        </article>
        <article class="form-card">
          <h3 data-i18n="subscribe-cn">Mainland China &middot; Feishu</h3>
          <p data-i18n="subscribe-cn-desc">中国大陆用户可通过飞书表单订阅。</p>
          <a class="form-link" href="https://sipeed-ai.feishu.cn/share/base/form/shrcnNqIl1NkOHPTQDI5nC0pbag" target="_blank" rel="noopener noreferrer" data-i18n="subscribe-btn-feishu">Subscribe via Feishu</a>
        </article>
      </div>

      <h2 class="section-label" style="margin-top:40px;" data-i18n="community-title">Join the Community</h2>
      <div class="community-grid">
        <article class="form-card community-card">
          <h3 data-i18n="community-wechat">WeChat Group</h3>
          <a href="https://raw.githubusercontent.com/sipeed/picoclaw/main/assets/wechat.png" target="_blank" rel="noopener noreferrer">
            <img src="https://raw.githubusercontent.com/sipeed/picoclaw/main/assets/wechat.png" alt="WeChat QR Code" style="width:140px;height:auto;border-radius:8px;margin:8px 0;" loading="lazy" />
          </a>
          <p data-i18n="community-wechat-desc" style="text-align:center;">Scan QR code to join the WeChat group.</p>
        </article>
        <article class="form-card community-card">
          <h3 data-i18n="community-discord">Discord Community</h3>
          <p data-i18n="community-discord-desc">Join our Discord server for discussions and support.</p>
          <a class="form-link" href="https://discord.gg/V4sAZ9XWpN" target="_blank" rel="noopener noreferrer" data-i18n="community-discord-btn">Join Discord</a>
        </article>
      </div>
    </section>
  </main>

