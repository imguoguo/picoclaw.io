    // ── Pure utility functions (no DOM dependency) ───────────
    function escapeHtml(str) {
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function formatReply(text) {
      // Convert code blocks
      var result = escapeHtml(text);
      result = result.replace(/```(\w*)\n([\s\S]*?)```/g, function(_, lang, code) {
        return '<pre><code>' + code + '</code></pre>';
      });
      // Bold
      result = result.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      // Line breaks (outside pre)
      result = result.replace(/\n/g, '<br/>');
      // Fix double br inside pre
      result = result.replace(/<pre><code>([\s\S]*?)<\/code><\/pre>/g, function(_, code) {
        return '<pre><code>' + code.replace(/<br\/>/g, '\n') + '</code></pre>';
      });
      return result;
    }

    function typeText(el: any, text: string, speed: number, cb: (() => void) | null) {
      var formatted = formatReply(text);
      el.innerHTML = '';
      var chars: number[] = [];
      var inTag = false;
      for (var c = 0; c < formatted.length; c++) {
        if (formatted[c] === '<') inTag = true;
        if (!inTag) chars.push(c);
        if (formatted[c] === '>') inTag = false;
      }
      var shown = 0;
      function tick() {
        shown += 3;
        if (shown >= chars.length) {
          el.innerHTML = formatted;
          if (cb) window._chatTimers?.push(setTimeout(cb, 100) as unknown as number);
          return;
        }
        var pos = chars[Math.min(shown, chars.length - 1)];
        el.innerHTML = formatted.substring(0, pos + 1);
        window._chatTimers?.push(setTimeout(tick, speed) as unknown as number);
      }
      tick();
    }

    // ── Page-load handler (runs on every navigation with View Transitions) ──
    document.addEventListener('astro:page-load', () => {
      // Clean up any previous chat timers from a prior page-load
      if (window._chatTimers) {
        window._chatTimers.forEach(function(id: number) { clearTimeout(id); });
      }
      window._chatTimers = [] as number[];

      // Guard: only run on homepage
      if (window.location.pathname !== '/') return;
      var chatBody = document.getElementById('chat-body');

      // ── i18n init ──
      function detectLang() {
        var saved = localStorage.getItem('lang');
        if (saved && TRANSLATIONS[saved]) return saved;
        return navigator.language.startsWith('zh') ? 'zh' : 'en';
      }

      var currentLang = detectLang();

      function t(key) {
        return (TRANSLATIONS[currentLang] || TRANSLATIONS.en)[key]
            || TRANSLATIONS.en[key]
            || key;
      }

      function applyStaticLang() {
        document.documentElement.lang = currentLang === 'zh' ? 'zh-CN' : 'en';
        document.querySelectorAll('[data-i18n]').forEach(function(el) {
          var val = t(el.dataset.i18n);
          if (typeof val === 'string' && val.indexOf('<') !== -1) el.innerHTML = val;
          else if (typeof val === 'string') el.textContent = val;
        });
      }

      function switchLang(lang) {
        currentLang = lang;
        localStorage.setItem('lang', lang);
        applyStaticLang();
        // Reset chat to show scenes in new language
        chatSceneIdx = 0;
        chatBody.innerHTML = '';
        window._chatTimers.forEach(function(id: number) { clearTimeout(id); });
        window._chatTimers = [];
        window._chatTimers.push(setTimeout(runScene, 500) as unknown as number);
      }

      window.addEventListener('lang-changed', function(e) {
        switchLang(e.detail.lang);
      });

      applyStaticLang();

      // ── Chat typewriter simulation ───────────────────────────
      function chatDelay(fn: () => void, ms: number) {
        var id = setTimeout(fn, ms);
        window._chatTimers.push(id as unknown as number);
      }

      var chatSceneIdx = 0;

      function runScene() {
        var scenes = CHAT_SCENES[currentLang] || CHAT_SCENES.en;
        var scene = scenes[chatSceneIdx % scenes.length];
        chatSceneIdx++;

        chatBody.innerHTML = '';

        // User message
        var userDiv = document.createElement('div');
        userDiv.className = 'chat-msg chat-user';
        userDiv.innerHTML = '<span class="chat-avatar">You</span><span class="chat-text">' + escapeHtml(scene.user) + '</span>';
        chatBody.appendChild(userDiv);

        // Thinking indicator
        chatDelay(function() {
          var thinkDiv = document.createElement('div');
          thinkDiv.className = 'chat-msg chat-bot';
          thinkDiv.innerHTML = '<span class="chat-avatar">\u{1F916}</span><span class="chat-text chat-thinking"><span class="dot-anim">\u25CF\u25CF\u25CF</span></span>';
          chatBody.appendChild(thinkDiv);
          chatBody.scrollTop = chatBody.scrollHeight;

          // Replace with typed reply
          chatDelay(function() {
            var replySpan = thinkDiv.querySelector('.chat-text');
            replySpan!.classList.remove('chat-thinking');
            typeText(replySpan, scene.reply, 25, function() {
              chatBody.scrollTop = chatBody.scrollHeight;
              // Wait then run next scene
              chatDelay(function() {
                // Fade out
                chatBody.style.opacity = '0';
                chatDelay(function() {
                  chatBody.style.opacity = '1';
                  runScene();
                }, 400);
              }, 4000);
            });
            chatBody.scrollTop = chatBody.scrollHeight;
          }, 800);
        }, 600);
      }

      // Start chat simulation after page load
      chatDelay(runScene, 1500);
    });
  </script>
